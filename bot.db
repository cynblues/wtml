import discord
from discord.ext import commands
from discord import option
import database


class Points(commands.Cog):
    def __init__(self, bot):
        self.bot = bot

    point_group = discord.SlashCommandGroup("point", "ระบบคะแนน")

    @point_group.command(name="balance", description="ตรวจสอบคะแนนของคุณหรือผู้อื่น")
    @option("user", discord.Member, description="ผู้ใช้ที่ต้องการตรวจสอบ (ไม่ระบุ = ตัวเอง)", required=False)
    @commands.cooldown(1, 10, commands.BucketType.user)
    async def balance(self, ctx: discord.ApplicationContext, user: discord.Member = None):
        target = user or ctx.author
        pts = await database.get_points(target.id, ctx.guild_id)

        embed = discord.Embed(
            title="💰  คะแนนของคุณ",
            color=discord.Color.from_rgb(88, 101, 242)
        )
        embed.set_thumbnail(url=target.display_avatar.url)
        embed.add_field(name="👤  ผู้ใช้", value=target.mention, inline=True)
        embed.add_field(name="⭐  คะแนน", value=f"**{pts:,}** คะแนน", inline=True)
        embed.set_footer(text=ctx.guild.name)
        await ctx.respond(embed=embed)

    @point_group.command(name="add", description="เพิ่มคะแนนให้ผู้ใช้ (แอดมิน)")
    @option("user", discord.Member, description="ผู้ใช้ที่ต้องการเพิ่มคะแนน")
    @option("amount", int, description="จำนวนคะแนนที่ต้องการเพิ่ม")
    @commands.has_permissions(manage_guild=True)
    @commands.cooldown(1, 3, commands.BucketType.user)
    async def add(self, ctx: discord.ApplicationContext, user: discord.Member, amount: int):
        if amount <= 0:
            await ctx.respond("❌ จำนวนคะแนนต้องมากกว่า 0", ephemeral=True)
            return
        await database.add_points(user.id, ctx.guild_id, amount)
        new_bal = await database.get_points(user.id, ctx.guild_id)
        embed = discord.Embed(
            title="✅  เพิ่มคะแนนสำเร็จ",
            color=discord.Color.from_rgb(40, 167, 69)
        )
        embed.set_thumbnail(url=user.display_avatar.url)
        embed.add_field(name="👤  ผู้ใช้", value=user.mention, inline=True)
        embed.add_field(name="➕  เพิ่ม", value=f"+{amount:,} คะแนน", inline=True)
        embed.add_field(name="⭐  คะแนนรวม", value=f"{new_bal:,} คะแนน", inline=True)
        embed.set_footer(text=f"ดำเนินการโดย {ctx.author.display_name}")
        await ctx.respond(embed=embed)

    @point_group.command(name="remove", description="ลดคะแนนของผู้ใช้ (แอดมิน)")
    @option("user", discord.Member, description="ผู้ใช้ที่ต้องการลดคะแนน")
    @option("amount", int, description="จำนวนคะแนนที่ต้องการลด")
    @commands.has_permissions(manage_guild=True)
    @commands.cooldown(1, 3, commands.BucketType.user)
    async def remove(self, ctx: discord.ApplicationContext, user: discord.Member, amount: int):
        if amount <= 0:
            await ctx.respond("❌ จำนวนคะแนนต้องมากกว่า 0", ephemeral=True)
            return
        current = await database.get_points(user.id, ctx.guild_id)
        success = await database.remove_points(user.id, ctx.guild_id, amount)
        if not success:
            await ctx.respond(
                f"❌ {user.mention} มีคะแนนเพียง **{current:,}** คะแนน ไม่สามารถลด **{amount:,}** ได้",
                ephemeral=True
            )
            return
        new_bal = await database.get_points(user.id, ctx.guild_id)
        embed = discord.Embed(
            title="✅  ลดคะแนนสำเร็จ",
            color=discord.Color.from_rgb(220, 53, 69)
        )
        embed.set_thumbnail(url=user.display_avatar.url)
        embed.add_field(name="👤  ผู้ใช้", value=user.mention, inline=True)
        embed.add_field(name="➖  ลด", value=f"-{amount:,} คะแนน", inline=True)
        embed.add_field(name="⭐  คะแนนรวม", value=f"{new_bal:,} คะแนน", inline=True)
        embed.set_footer(text=f"ดำเนินการโดย {ctx.author.display_name}")
        await ctx.respond(embed=embed)

    @point_group.command(name="leaderboard", description="อันดับคะแนนสูงสุดในเซิร์ฟเวอร์")
    @commands.cooldown(1, 30, commands.BucketType.guild)
    async def leaderboard(self, ctx: discord.ApplicationContext):
        await ctx.defer()
        rows = await database.get_leaderboard(ctx.guild_id)
        if not rows:
            await ctx.respond("📭 ยังไม่มีข้อมูลคะแนน", ephemeral=True)
            return

        embed = discord.Embed(
            title=f"🏆  อันดับคะแนน  —  {ctx.guild.name}",
            color=discord.Color.from_rgb(255, 193, 7)
        )
        medals = {1: "🥇", 2: "🥈", 3: "🥉"}
        lines = []
        for i, (user_id, pts) in enumerate(rows, 1):
            medal = medals.get(i, f"`#{i}`")
            try:
                member = ctx.guild.get_member(user_id) or await ctx.guild.fetch_member(user_id)
                name = member.display_name
            except Exception:
                name = f"User {user_id}"
            lines.append(f"{medal}  **{name}** — {pts:,} คะแนน")

        embed.description = "\n".join(lines)
        embed.set_footer(text=f"แสดง {len(rows)} อันดับแรก")
        await ctx.respond(embed=embed)

    @add.error
    @remove.error
    async def admin_error(self, ctx, error):
        if isinstance(error, commands.MissingPermissions):
            await ctx.respond("❌ คุณต้องมีสิทธิ์ **จัดการเซิร์ฟเวอร์** เพื่อใช้คำสั่งนี้", ephemeral=True)
        elif isinstance(error, commands.CommandOnCooldown):
            await ctx.respond(
                f"⏳ กรุณารอ **{error.retry_after:.1f} วินาที** ก่อนใช้คำสั่งนี้อีกครั้ง",
                ephemeral=True
            )

    @balance.error
    @leaderboard.error
    async def cooldown_error(self, ctx, error):
        if isinstance(error, commands.CommandOnCooldown):
            await ctx.respond(
                f"⏳ กรุณารอ **{error.retry_after:.1f} วินาที** ก่อนใช้คำสั่งนี้อีกครั้ง",
                ephemeral=True
            )


def setup(bot):
    bot.add_cog(Points(bot))
